# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# tenant data — only sample-tenant is public
/data/tenants/*
!/data/tenants/sample-tenant

# internal docs (PLAN.md, DESIGN.md, etc.)
/docs/internal/

# editor / IDE
.vscode/
.idea/

# OS
Thumbs.db

# claude code local settings (launch.json is committed; settings.local.json is not)
.claude/settings.local.json
.claude/skills/

# private notes (do NOT commit)
PRIVATE_*.md
NOTES_*.md
*.local.*
